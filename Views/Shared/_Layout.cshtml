@if(TempData["message"] != null) {
<div class="mt-5 alert alert-warning">@TempData["message"]</div>
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>E-Ticaret Sitesi</title>
    <link rel="stylesheet" href="/css/main.css">
      <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" >
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css"
    />
<link rel="stylesheet" href="~/css/main.css">
</head>
<body>

       <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm py-3">
       <div class="container">
        <a class="navbar-brand fw-bold fs-4" href="#">
          <img
            src="https://upload.wikimedia.org/wikipedia/commons/a/a6/Logo_NIKE.svg"
            alt="Nike"
            height="30"
          />
        </a>

        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#nikeNavbar"
        >
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="nikeNavbar">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item">
              <a class="nav-link" href="#">Yeni Gelenler</a>
            </li>
            <li class="nav-item"><a class="nav-link" href="#">Erkek</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Kadın</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Çocuk</a></li>
            <li class="nav-item"><a class="nav-link" href="#">İndirim</a></li>
          </ul>

            <ul class="navbar-nav mb-2 mb-lg-0 d-flex align-items-center gap-3">
        <li class="nav-item">
          <a class="nav-link" href="#">
            <i class="bi bi-search fs-5"></i>
          </a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="/cart">
            <i class="bi bi-cart fs-5"></i>
          </a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="/profile">
            <i class="bi bi-person fs-5"></i>
          </a>
        </li>

        <li class="nav-item">
          <form  method="post" class="m-0 p-0">
            <button type="submit" class="btn btn-link nav-link p-0">
              <i class="bi bi-box-arrow-right fs-5"></i>
            </button>
          </form>
        </li>
      </ul>
        </div>
      </div>
    </nav>

    <div class="container" style="margin-top: 70px;">
        @RenderBody()
    </div>
    
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>