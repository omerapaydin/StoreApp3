@model List<Product> 
<div class="row">
  <div class="col-md-3 mb-4">
      <div class="card shadow-sm border-0 rounded-4 p-3 bg-light">
        <h5 class="fw-bold text-center mb-4">
            <a class="btn btn-dark text-white w-100 py-3" href="/Home/List" style="text-decoration: none; color: white; font-size: 1.1rem;">Kategoriler</a>
        </h5>
        <ul class="list-group list-group-flush">
            <li class="list-group-item bg-transparent border-0">
                <a class="text-decoration-none text-dark fw-semibold d-block text-center py-3 category-link">
                    Ayakkabı
                </a>
            </li>
            <li class="list-group-item bg-transparent border-0">
                <a class="text-decoration-none text-dark fw-semibold d-block text-center py-3 category-link">
                    Kıyafet
                </a>
            </li>
            <li class="list-group-item bg-transparent border-0">
                <a class="text-decoration-none text-dark fw-semibold d-block text-center py-3 category-link">
                    Aksesuarlar
                </a>
            </li>
        </ul>
    </div>
  </div>

  <div class="col-md-9">
    <div class="row row-cols-1 row-cols-md-3 g-4">
      @foreach(var prd in Model)
      {
       <div class="col">
            <div class="card product-card h-100">
               <a href="/Home/Details/@prd.ProductId">
                <img src="~/img/@prd.Image" class="card-img-top" alt="@prd.Title" style="object-fit: cover; height: 400px;" /></a>
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <h6 class="card-title">@prd.Title</h6>
                        <p class="card-text text-muted">@prd.Description</p>
                        <p class="fw-bold">₺@prd.Price</p>
                    </div>
                </div>
            </div>
         </div>
        }
    </div>
  </div>
</div>